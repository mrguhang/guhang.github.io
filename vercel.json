{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/students", "dest": "/api/students.js" },
    { "src": "/api/students/(.*)", "dest": "/api/students.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
